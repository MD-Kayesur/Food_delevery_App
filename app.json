{
  "expo": {
    "name": "Food_Delevery",
    "slug": "Food_Delevery",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/logo.png",
    "scheme": "fooddelevery",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/logo.png"
    },
    "android": {
      "icon": "./assets/logo.png",
      "adaptiveIcon": {
        "backgroundColor": "#000000",
        "foregroundImage": "./assets/images/android-icon-foreground.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.md_kayesur.Food_Delevery"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/logo.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#121212",
          "android": {
            "image": "./assets/logo.png",
            "imageWidth": 200
          }
        }
      ],
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "22dcb03f-ea1a-4078-92eb-90c465828f1e"
      }
    }
  }
}
